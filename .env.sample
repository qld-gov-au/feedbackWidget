# reCAPTCHA v3 site keys (public — safe to commit to .env.sample, NOT the secret keys)
# Each key must be paired with the matching secret key configured in the SSQ backend
RECAPTCHA_DEV=TEST_DEV_KEY
RECAPTCHA_PROD=TEST_PROD_KEY

# Smart Service endpoint paths
# Final action path is /services/submissions/email/{FSH_PROJECT}/{selected endpoint}
# Build mode chooses endpoint automatically:
# build:dev -> FSH_ENDPOINT_DEV, build:uat -> FSH_ENDPOINT_UAT, build:prod -> FSH_ENDPOINT_PROD.
FSH_PROJECT=feedback
FSH_ENDPOINT_DEV=feedback-v4
FSH_ENDPOINT_UAT=feedback-v4
FSH_ENDPOINT_PROD=feedback-v4

# Smoke-test endpoint override (recommended)
# Use a non-existent or test-only endpoint so smoke tests cannot send real emails
# even if a Playwright route mock fails to intercept a request.
SMOKE_FSH_ENDPOINT=feedback-smoke-test

# Playwright browser mode
# true: headless (recommended local default)
# false: headed (useful for local debugging)
PLAYWRIGHT_HEADLESS=true

# BrowserStack (local developer usage only; not used by GitHub Actions)
# Get values from your BrowserStack Automate account settings.
BROWSERSTACK_USERNAME=
BROWSERSTACK_ACCESS_KEY=

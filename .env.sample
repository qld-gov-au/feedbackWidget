# reCAPTCHA v3 site keys (public — safe to commit to .env.sample, NOT the secret keys)
# Each key must be paired with the matching secret key configured in the SSQ backend
RECAPTCHA_DEV=
RECAPTCHA_PROD=

# Smart Service endpoint path (optional)
# Final action path is /services/submissions/email/{FSH_PROJECT}/{FSH_ENDPOINT}
FSH_PROJECT=feedback
FSH_ENDPOINT=feedback-v4

# Playwright browser mode
# true: headless (recommended local default)
# false: headed (useful for local debugging)
PLAYWRIGHT_HEADLESS=true

# BrowserStack (local developer usage only; not used by GitHub Actions)
# Get values from your BrowserStack Automate account settings.
BROWSERSTACK_USERNAME=
BROWSERSTACK_ACCESS_KEY=